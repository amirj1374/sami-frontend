# Base URL the SPA uses for API calls.
# In dev, Vite proxies "/api" to the backend (see vite.config.ts), so the default
# same-origin value works without change.
VITE_API_BASE_URL=/api

# Optional: override the dev proxy target (defaults to http://localhost:8080).
# VITE_DEV_API_TARGET=http://localhost:8080
